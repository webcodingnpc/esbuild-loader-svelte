{
    "name": "esbuild-loader-svelte",
    "version": "1.0.0",
    "type": "module",
    "description": "esbuild 插件集合：编译 Svelte 5 组件、SCSS 样式、SSR 空桩、源码导入、元信息提取",
    "keywords": [
        "esbuild",
        "svelte",
        "svelte5",
        "scss",
        "plugin",
        "ssr"
    ],
    "license": "MIT",
    "author": "free-walk",
    "repository": {
        "type": "git",
        "url": "https://github.com/webcodingnpc/esbuild-loader-svelte.git"
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "exports": {
        ".": {
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs",
            "default": "./dist/index.mjs"
        },
        "./svelte": {
            "import": "./src/SveltePlugin.js",
            "require": "./dist/index.cjs"
        },
        "./scss": {
            "import": "./src/ScssPlugin.js",
            "require": "./dist/index.cjs"
        },
        "./ssr-stub": {
            "import": "./src/SsrStubPlugin.js",
            "require": "./dist/index.cjs"
        },
        "./raw": {
            "import": "./src/RawPlugin.js",
            "require": "./dist/index.cjs"
        },
        "./meta": {
            "import": "./src/MetaPlugin.js",
            "require": "./dist/index.cjs"
        },
        "./templates": {
            "import": "./src/TemplateEngine.js",
            "require": "./dist/index.cjs"
        },
        "./obfuscator": {
            "import": "./src/ObfuscatorPlugin.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist",
        "src",
        "index.js",
        "README.md"
    ],
    "scripts": {
        "build": "node scripts/build.js"
    },
    "peerDependencies": {
        "esbuild": ">=0.17.0",
        "svelte": "^5.0.0"
    },
    "peerDependenciesMeta": {
        "svelte": {
            "optional": true
        }
    },
    "devDependencies": {
        "esbuild": "^0.27.4",
        "sass": "^1.98.0",
        "svelte": "^5.55.1"
    },
    "optionalDependencies": {
        "javascript-obfuscator": "^4.2.2",
        "sass": "^1.50.0"
    }
}